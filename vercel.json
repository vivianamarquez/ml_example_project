{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ],
  "functions": {
    "api/index.py": {
      "excludeFiles": "{.git/**,.ipynb_checkpoints/**,**/*.ipynb,reference/**,static/shap_outputs/**,__pycache__/**,*.pyc}"
    }
  }
}
